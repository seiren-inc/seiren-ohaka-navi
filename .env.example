# 環境変数テンプレート（.env.example）
# 実際の値は .env.local（ローカル）または Vercel Environment Variables（本番）に設定する
# このファイルは Git 管理対象。秘密情報は絶対に記載しないこと。

# =============================
# Prisma / Database
# =============================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# =============================
# Supabase
# =============================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[your-anon-key]"
SUPABASE_SERVICE_ROLE_KEY="[your-service-role-key]"

# =============================
# Admin
# =============================
ADMIN_ALLOWLIST="admin@example.com"
ADMIN_USER="[your-admin-user]"
ADMIN_PASSWORD="[your-admin-password]"

# =============================
# Site URL
# =============================
# 本番: https://ohakanavi.jp
# ローカル: http://localhost:3000
NEXT_PUBLIC_SITE_URL="https://ohakanavi.jp"
NEXT_PUBLIC_BASE_URL="https://ohakanavi.jp"

# =============================
# Stripe
# =============================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_STANDARD_PRICE_ID="price_..."
